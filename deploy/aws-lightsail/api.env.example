# Copy to /etc/mpac/api.env on the Lightsail host and fill in with
# the real secrets. Never commit the populated file — it's in .gitignore.
#
# Generate JWT_SECRET:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
# Generate ENCRYPTION_KEY:
#   python3 -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
#   (if python3 lacks cryptography, pip install cryptography first, or use
#    base64.urlsafe_b64encode(secrets.token_bytes(32)).decode() as fallback)

MPAC_WEB_JWT_SECRET=paste_48_urlsafe_chars_here
MPAC_WEB_ENCRYPTION_KEY=paste_fernet_key_here
MPAC_WEB_INVITE_CODES=mpac-beta-4j9fvg,mpac-beta-vzneutmv,mpac-beta-crsrgyd,mpac-beta-rsyi5ux,mpac-beta-sh9ql6dc,mpac-beta-5pq1zyc,mpac-beta-cdw9qie3,mpac-beta-dsnchglx,mpac-beta-sy8dmfc,mpac-beta-a6p2nx6
MPAC_WEB_ALLOWED_ORIGINS=https://your.domain.here
