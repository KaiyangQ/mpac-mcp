# Caddy config for the hosted MPAC coordinator — Authenticated profile edition.
#
# Responsibilities:
#   1. Listen on :8080 (TLS is done by fly-proxy, not here)
#   2. Only forward /session/* paths to the sidecar (type filter, not auth;
#      keeps drive-by scans for /wp-admin / /.env / etc. out of sidecar logs)
#   3. Forward WebSocket upgrades transparently (Caddy v2 handles this
#      automatically on reverse_proxy routes)
#
# NOTE: Authentication is NOT done at this layer anymore. The sidecar runs
# in Authenticated profile (Section 23.1.4) and its credential_verifier
# enforces per-token -> per-session authorization via MPAC_TOKEN_TABLE.
# Single source of truth for auth = one fewer token to manage = better UX.

{
    admin off
    auto_https off
    persist_config off
}

:8080 {
    @session path /session/*
    handle @session {
        reverse_proxy 127.0.0.1:8766
    }
    handle {
        respond "not found — expected /session/<id>" 404
    }
}
